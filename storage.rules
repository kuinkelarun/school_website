rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated();
    }

    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPdfFile() {
      return request.resource.contentType == 'application/pdf';
    }

    function isValidSize() {
      return request.resource.size < 10 * 1024 * 1024; // 10MB max
    }

    // Hero images - Public read, admin write
    match /hero-images/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImageFile() && isValidSize();
    }

    // Announcements - Public read, admin write
    match /announcements/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && (isImageFile() || isPdfFile()) && isValidSize();
    }

    // Events - Public read, admin write
    match /events/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImageFile() && isValidSize();
    }

    // Programs - Public read, admin write
    match /programs/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && (isImageFile() || isPdfFile()) && isValidSize();
    }

    // Media library - Public read, admin write
    match /media/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isValidSize();
    }

    // Faculty photos - Public read, admin write
    match /faculty/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImageFile() && isValidSize();
    }

    // Site settings (logo, etc) - Public read, admin write
    match /site/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImageFile() && isValidSize();
    }

    // Gallery - Public read, admin write
    match /gallery/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isValidSize();
    }

    // Faculty files - Owner read/write (3MB per file), admin read
    match /faculty-files/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId
                   && request.resource.size < 3 * 1024 * 1024;
      allow delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
  }
}
