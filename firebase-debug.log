[debug] [2026-03-04T02:02:50.391Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/janatamavi-edu/rulesets {"name":"projects/janatamavi-edu/rulesets/a6bb5e7d-48fe-4b53-8171-7e88d07bebf3","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    // Helper functions\r\n    function isAuthenticated() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function isAdmin() {\r\n      return isAuthenticated() &&\r\n             exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)) &&\r\n             get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.isActive == true;\r\n    }\r\n\r\n    // Hero Images - Public read, admin write\r\n    match /heroImages/{document} {\r\n      allow read: if true;\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Announcements - Published content is public, admin can see all\r\n    match /announcements/{document} {\r\n      allow read: if resource.data.isPublished == true || isAdmin();\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Events - Published content is public, admin can see all\r\n    match /events/{document} {\r\n      allow read: if resource.data.isPublished == true || isAdmin();\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Programs - Published content is public, admin can see all\r\n    match /programs/{document} {\r\n      allow read: if resource.data.isPublished == true || isAdmin();\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Contact Messages - Anyone can create, only admin can read/update\r\n    match /contactMessages/{document} {\r\n      allow read: if isAdmin();\r\n      allow create: if true; // Anyone can submit contact form\r\n      allow update, delete: if isAdmin();\r\n    }\r\n\r\n    // Admin Users - Admins can manage all; users can read their own doc\r\n    match /adminUsers/{userId} {\r\n      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());\r\n      allow create: if isAdmin();\r\n      allow update: if isAdmin();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // Site Settings - Public read, admin write\r\n    match /siteSettings/{document} {\r\n      allow read: if true;\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Faculty - Published content is public, admin can manage\r\n    match /faculty/{document} {\r\n      allow read: if resource.data.isPublished == true || isAdmin();\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Gallery - Published content is public, admin can manage\r\n    match /gallery/{document} {\r\n      allow read: if resource.data.isPublished == true || isAdmin();\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Media Files - Admin only\r\n    match /mediaFiles/{document} {\r\n      allow read, write: if isAdmin();\r\n    }\r\n\r\n    // Mail collection - Trigger Email extension reads; anyone can create\r\n    // (contact form creates documents, Cloud Functions also write here)\r\n    match /mail/{document} {\r\n      allow create: if true;\r\n      allow read, update, delete: if isAdmin();\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-03-04T02:02:40.610447Z","metadata":{"services":["cloud.firestore"]}}
