rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.isActive == true;
    }

    function isFacultyUser() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/facultyUsers/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/facultyUsers/$(request.auth.uid)).data.isApproved == true &&
             get(/databases/$(database)/documents/facultyUsers/$(request.auth.uid)).data.isActive == true;
    }

    // Hero Images - Public read, admin write
    match /heroImages/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements - Published content is public, admin can see all
    match /announcements/{document} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // Events - Published content is public, admin can see all
    match /events/{document} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // Programs - Published content is public, admin can see all
    match /programs/{document} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // Articles - Published content is public, admin can see all
    match /articles/{document} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow create, delete: if isAdmin();
      // Admins can update anything; public can only increment viewCount
      allow update: if isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'updatedAt']);
    }

    // Contact Messages - Anyone can create, only admin can read/update
    match /contactMessages/{document} {
      allow read: if isAdmin();
      allow create: if true; // Anyone can submit contact form
      allow update, delete: if isAdmin();
    }

    // Article Submissions - Anyone can submit, only admin can read/manage
    match /articleSubmissions/{document} {
      allow read, update, delete: if isAdmin();
      allow create: if true; // Anyone can submit an article
    }

    // Admin Users - Admins can manage all; users can read their own doc
    match /adminUsers/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Site Settings - Public read, admin write
    match /siteSettings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Faculty - Published content is public, authenticated users can read (for registration email check), admin can manage
    match /faculty/{document} {
      allow read: if resource.data.isPublished == true || isAuthenticated() || isAdmin();
      allow write: if isAdmin();
    }

    // Gallery - Published content is public, admin can manage
    match /gallery/{document} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // Media Files - Admin only
    match /mediaFiles/{document} {
      allow read, write: if isAdmin();
    }

    // Mail collection - Trigger Email extension reads; anyone can create
    // (contact form creates documents, Cloud Functions also write here)
    match /mail/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Faculty Users - Self-create on registration, admin manages approval
    match /facultyUsers/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin() ||
        (isAuthenticated() && request.auth.uid == userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['storageUsed', 'lastLogin', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // Faculty Folders - Owner read/write, admin read
    match /facultyFolders/{folderId} {
      allow create: if isFacultyUser() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin() ||
        (isFacultyUser() && resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isFacultyUser() && resource.data.ownerId == request.auth.uid);
    }

    // Faculty Files - Owner read/write, admin read
    match /facultyFiles/{fileId} {
      allow create: if isFacultyUser() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isAdmin() ||
        (isFacultyUser() && resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isFacultyUser() && resource.data.ownerId == request.auth.uid);
    }
  }
}
